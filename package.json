{
  "name": "docvault",
  "version": "1.0.0",
  "description": "Gestão segura de documentos com Express, SQLite e frontend HTML.",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --legacy-watch --watch src --watch public src/server.js",
    "check": "node -c src/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^12.2.0",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "google-auth-library": "^9.15.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
